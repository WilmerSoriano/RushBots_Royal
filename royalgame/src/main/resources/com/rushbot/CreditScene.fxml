<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="primaryControllerLayer" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rushbot.PrimaryController">
   <children>
      <AnchorPane fx:id="credits" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="700.0">
         <children>
            <Label fx:id="title1" alignment="CENTER" layoutY="95.0" prefHeight="100.0" prefWidth="700.0" styleClass="title-glow" text="Thank you !" textAlignment="CENTER">
               <font>
                  <Font name="Cooper Black" size="50.0" />
               </font>
            </Label>
            <TextArea fx:id="letter" editable="false" layoutX="-2.0" layoutY="250.0" prefHeight="200.0" prefWidth="700.0" promptText="Hello players" text="                                                        Thank you for playing my game!&#10;&#10;A solo project made by me, but not entirely possible without videos provided by Bro Code.&#10;Designing and front-end is not my forte, so yes I used LLM for CSS designs ¬_¬, But all logic of the game and mechanics were coded by me alone╰(*°▽°*)╯.&#10;&#10;                                                        I had fun and I hope you did as well!&#10;                                            Feel free to contact me or contribute to my game.&#10;                                                                           See you around!" wrapText="true">
               <font>
                  <Font name="Cooper Black" size="14.0" />
               </font>
            </TextArea>
            <GridPane alignment="CENTER" layoutY="504.0" prefHeight="100.0" prefWidth="692.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="341.0" minWidth="10.0" prefWidth="207.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="550.0" minWidth="10.0" prefWidth="485.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" valignment="BOTTOM" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Text fill="#58bcfa" strokeType="OUTSIDE" strokeWidth="0.0" text="Bro Code channel: " textAlignment="RIGHT" wrappingWidth="208.669921875">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Text>
                  <Text fill="#58bcfa" strokeType="OUTSIDE" strokeWidth="0.0" text="Contribute here: " textAlignment="RIGHT" wrappingWidth="212.13671875" GridPane.rowIndex="1">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Text>
                  <Hyperlink fx:id="web_youtube" onAction="#openYoutube" prefHeight="23.0" prefWidth="492.0" text="https://www.youtube.com/@BroCodez" underline="true" GridPane.columnIndex="1">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Hyperlink>
                  <Hyperlink fx:id="web_github" onAction="#openGithub" prefHeight="23.0" prefWidth="537.0" text="My GitHub Repository" underline="true" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Hyperlink>
               </children>
            </GridPane>
            <Button fx:id="return_back" layoutX="285.0" layoutY="629.0" mnemonicParsing="false" onAction="#onReturn" prefHeight="35.0" prefWidth="130.0" text="Back">
               <font>
                  <Font name="Bodoni MT Bold" size="18.0" />
               </font></Button>
         </children>
      </AnchorPane>
   </children>
</StackPane>
