<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="primaryControllerLayer" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rushbot.PrimaryController">
   <children>
      <Pane fx:id="coinLayer" prefHeight="700.0" prefWidth="700.0" />
      <AnchorPane fx:id="gameMenu" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="700.0">
         <children>
            <VBox fx:id="menu_vbox" alignment="CENTER" layoutX="2.0" layoutY="260.0" prefHeight="178.0" prefWidth="700.0" spacing="10.0">
               <children>
                  <Button fx:id="start_button" styleClass="menu-button" mnemonicParsing="false" onAction="#startGame" prefHeight="30.0" prefWidth="220.0" text="Start Game!" textAlignment="CENTER">
                     <font>
                        <Font name="Bodoni MT Bold" size="18.0" />
                     </font>
                  </Button>
                  <Button fx:id="load_button" styleClass="menu-button" mnemonicParsing="false" onAction="#loadGame" prefHeight="30.0" prefWidth="220.0" text="Load Game">
                     <font>
                        <Font name="Bodoni MT Bold" size="18.0" />
                     </font>
                  </Button>
                  <Button fx:id="credit_button" styleClass="menu-button" mnemonicParsing="false" onAction="#showCredit" prefHeight="30.0" prefWidth="220.0" text="Credits">
                     <font>
                        <Font name="Bodoni MT Bold" size="18.0" />
                     </font>
                  </Button>
                  <Button fx:id="setting_button" styleClass="menu-button" mnemonicParsing="false" onAction="#showSettings" prefHeight="30.0" prefWidth="220.0" text="Settings">
                     <font>
                        <Font name="Bodoni MT Bold" size="18.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
            <Label fx:id="title1" styleClass="title-glow" alignment="CENTER" layoutX="-1.0" layoutY="78.0" prefHeight="100.0" prefWidth="700.0" text="Rush Bots" textAlignment="CENTER">
               <font>
                  <Font name="Cooper Black" size="50.0" />
               </font>
            </Label>
            <Label fx:id="title2" styleClass="title-glow" alignment="CENTER" layoutX="2.0" layoutY="128.0" prefHeight="100.0" prefWidth="700.0" text="Royal" textAlignment="CENTER">
               <font>
                  <Font name="Cooper Black" size="50.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
   </children>
</StackPane>
